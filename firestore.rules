rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Standardized membership check for map-based roles
    function isMember(data) {
      return isSignedIn() && 
             data != null && 
             data.memberRoles != null && 
             data.memberRoles[request.auth.uid] != null;
    }

    function isAdmin(data) {
      return isSignedIn() && 
             data != null && 
             data.memberRoles != null && 
             (data.memberRoles[request.auth.uid] == 'admin' || data.memberRoles[request.auth.uid] == 'owner');
    }

    // --- COLLECTION GROUP RULES ---
    // Mandatory for collectionGroup() queries. These MUST use resource.data.
    
    match /{path=**}/tasks/{taskId} {
      allow list, get: if isMember(resource.data);
    }

    match /{path=**}/comments/{commentId} {
      allow list, get: if isMember(resource.data);
    }

    // --- HIERARCHICAL COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; 
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    match /workspaces/{workspaceId} {
      // Helper to check membership on the workspace document itself
      function isWsMember() {
        let ws = get(/databases/$(database)/documents/workspaces/$(workspaceId)).data;
        return isSignedIn() && (ws.ownerUserId == request.auth.uid || ws.memberRoles[request.auth.uid] != null);
      }

      function isWsAdmin() {
        let ws = get(/databases/$(database)/documents/workspaces/$(workspaceId)).data;
        return isSignedIn() && (ws.ownerUserId == request.auth.uid || ws.memberRoles[request.auth.uid] == 'admin' || ws.memberRoles[request.auth.uid] == 'owner');
      }

      // Root workspace listing requires the memberRoles filter
      allow list: if isMember(resource.data);
      allow get: if isWsMember();
      allow create: if isSignedIn() && request.resource.data.ownerUserId == request.auth.uid;
      allow update: if resource != null && isWsAdmin();
      allow delete: if resource != null && resource.data.ownerUserId == request.auth.uid;

      match /members/{memberUserId} {
        allow get, list: if isWsMember() || isOwner(memberUserId);
        allow create, update, delete: if isWsAdmin();
      }

      match /projects/{projectId} {
        allow get, list: if isWsMember();
        allow create, update, delete: if isWsAdmin();

        match /tasks/{taskId} {
          allow get, list: if isWsMember();
          allow create, update: if isWsMember();
          allow delete: if isWsAdmin();

          match /comments/{commentId} {
            allow get, list: if isWsMember();
            allow create: if isWsMember() && request.resource.data.authorUserId == request.auth.uid;
            allow update: if resource != null && (isOwner(resource.data.authorUserId) || isWsAdmin());
            allow delete: if resource != null && (isOwner(resource.data.authorUserId) || isWsAdmin());
          }
        }
      }
    }
  }
}