rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function workspaceDoc(workspaceId) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId));
    }

    function projectDoc(workspaceId, projectId) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId)/projects/$(projectId));
    }

    function isWorkspaceMember(workspaceId) {
      return isSignedIn() && workspaceDoc(workspaceId).data.memberRoles[request.auth.uid] != null;
    }

    function isWorkspaceAdmin(workspaceId) {
      return isSignedIn() && (
        workspaceDoc(workspaceId).data.ownerUserId == request.auth.uid ||
        (workspaceDoc(workspaceId).data.memberRoles[request.auth.uid] in ['owner', 'lead'])
      );
    }

    function canAccessProject(workspaceId, projectId) {
      let proj = projectDoc(workspaceId, projectId);
      return isWorkspaceAdmin(workspaceId) ||
        (proj.data.allowedUserIds != null &&
         proj.data.allowedUserIds.hasAny([request.auth.uid]));
    }

    // --- NOTIFICATIONS RULES (FIXED) ---
    match /notifications/{notificationId} {
      // Read: user can only read their own notifications
      // For LIST queries: Firestore will verify the query includes userId filter
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Create: actor must be the authenticated user
      allow create: if isSignedIn() && 
                    request.resource.data.actorId == request.auth.uid &&
                    request.resource.data.userId is string;
      
      // Update/Delete: only the recipient can do this
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- HIERARCHICAL RULES ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /workspaces/{workspaceId} {
      // Read/Create: any signed-in user can create; read only if a member.
      allow create: if isSignedIn();
      allow read: if isWorkspaceMember(workspaceId);
      // Update: admins only (prevents arbitrary users from editing workspace membership/roles)
      allow update: if isWorkspaceAdmin(workspaceId);
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerUserId == request.auth.uid;

      match /members/{memberUserId} {
        allow read: if isWorkspaceMember(workspaceId);
        allow write: if isWorkspaceAdmin(workspaceId);
      }

      match /projects/{projectId} {
        allow read: if isWorkspaceMember(workspaceId) && canAccessProject(workspaceId, projectId);
        allow create, update, delete: if isWorkspaceAdmin(workspaceId);

        match /tasks/{taskId} {
          allow read: if isWorkspaceMember(workspaceId) && canAccessProject(workspaceId, projectId);
          allow create, update, delete: if isWorkspaceAdmin(workspaceId);

          match /comments/{commentId} {
            allow read: if isWorkspaceMember(workspaceId) && canAccessProject(workspaceId, projectId);
            // Let any project member comment, but keep membership enforced.
            allow create, update, delete: if isWorkspaceMember(workspaceId) && canAccessProject(workspaceId, projectId);
          }
        }
      }
    }
    
    // --- INVITATIONS ---
    match /invitations/{invitationId} {
      allow read: if true;
      // Creation/updating invites should be done by admins (enforced by client + rules).
      // Note: invite docs include workspaceId, so we can validate admin status.
      allow create: if isSignedIn() && isWorkspaceAdmin(request.resource.data.workspaceId);
      allow update, delete: if isSignedIn() && isWorkspaceAdmin(resource.data.workspaceId);
    }
  }
}