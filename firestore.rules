
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isMemberOfWs(wsId) {
      let ws = get(/databases/$(database)/documents/workspaces/$(wsId)).data;
      return isSignedIn() && (ws.ownerUserId == request.auth.uid || (ws.memberRoles != null && ws.memberRoles[request.auth.uid] != null));
    }

    // --- COLLECTION GROUP RULES ---
    
    match /{path=**}/tasks/{taskId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/comments/{commentId} {
      allow read: if isSignedIn();
    }

    // --- HIERARCHICAL COLLECTION RULES ---

    match /users/{userId} {
      allow get, create, update: if isOwner(userId);
      allow list: if false; 
    }

    match /workspaces/{workspaceId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isMemberOfWs(workspaceId);

      match /members/{memberUserId} {
        allow read: if isSignedIn();
        allow write: if isMemberOfWs(workspaceId);
      }

      match /projects/{projectId} {
        allow read: if isSignedIn();
        allow write: if isMemberOfWs(workspaceId);

        match /tasks/{taskId} {
          allow read: if isSignedIn();
          allow write: if isMemberOfWs(workspaceId);

          match /comments/{commentId} {
            allow read: if isSignedIn();
            allow write: if isMemberOfWs(workspaceId);
          }
        }
      }
    }
  }
}
