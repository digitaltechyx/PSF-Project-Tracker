rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getWorkspace(wsId) {
      return get(/databases/$(database)/documents/workspaces/$(wsId)).data;
    }

    function isWorkspaceMember(wsId) {
      let ws = getWorkspace(wsId);
      return isSignedIn() && (
        ws.ownerUserId == request.auth.uid || 
        (ws.memberRoles != null && ws.memberRoles[request.auth.uid] != null)
      );
    }

    function isWorkspaceAdmin(wsId) {
      let ws = getWorkspace(wsId);
      return isSignedIn() && (
        ws.ownerUserId == request.auth.uid || 
        (ws.memberRoles != null && (ws.memberRoles[request.auth.uid] == 'lead' || ws.memberRoles[request.auth.uid] == 'owner'))
      );
    }

    // --- COLLECTION GROUP RULES ---
    
    match /{path=**}/tasks/{taskId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/comments/{commentId} {
      allow read: if isSignedIn();
    }

    // --- HIERARCHICAL RULES ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && request.query.limit <= 5;
      allow create, update: if isOwner(userId);
    }

    match /invitations/{inviteId} {
      allow get: if true;
      allow list: if isSignedIn() && isWorkspaceAdmin(resource.data.workspaceId);
      allow create: if isSignedIn() && isWorkspaceAdmin(request.resource.data.workspaceId);
      allow update, delete: if isSignedIn() && isWorkspaceAdmin(resource.data.workspaceId);
    }

    match /workspaces/{workspaceId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isWorkspaceAdmin(workspaceId);

      match /members/{memberUserId} {
        allow read: if isSignedIn();
        allow write: if isWorkspaceAdmin(workspaceId);
      }

      match /projects/{projectId} {
        allow read: if isSignedIn();
        allow write: if isWorkspaceAdmin(workspaceId);

        match /tasks/{taskId} {
          allow read: if isSignedIn();
          allow write: if isWorkspaceMember(workspaceId);

          match /comments/{commentId} {
            allow read: if isSignedIn();
            allow write: if isWorkspaceMember(workspaceId);
          }
        }
      }
    }
  }
}
