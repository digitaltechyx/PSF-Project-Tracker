
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // --- NOTIFICATIONS RULES ---
    match /notifications/{notificationId} {
      // Standard pattern for user-owned data:
      // This covers both 'get' (single doc) and 'list' (collection queries).
      // For 'list', the client must filter by userId == auth.uid.
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Allow any authenticated user to create a notification for another user
      allow create: if isSignedIn() && request.resource.data.actorId == request.auth.uid;
      
      // Only the recipient can update (mark as read) or delete their notifications
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- COLLECTION GROUP RULES ---
    
    match /{path=**}/tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /{path=**}/comments/{commentId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- HIERARCHICAL RULES ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /workspaces/{workspaceId} {
      allow read, create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerUserId == request.auth.uid;

      match /members/{memberUserId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /projects/{projectId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();

        match /tasks/{taskId} {
          allow read: if isSignedIn();
          allow write: if isSignedIn();

          match /comments/{commentId} {
            allow read: if isSignedIn();
            allow write: if isSignedIn();
          }
        }
      }
    }
  }
}
