rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getWorkspace(wsId) {
      return get(/databases/$(database)/documents/workspaces/$(wsId)).data;
    }

    function isWorkspaceMember(wsId) {
      let ws = getWorkspace(wsId);
      return isSignedIn() && (
        ws.ownerUserId == request.auth.uid || 
        (ws.memberRoles != null && ws.memberRoles[request.auth.uid] != null)
      );
    }

    function isWorkspaceAdmin(wsId) {
      let ws = getWorkspace(wsId);
      let role = ws.memberRoles[request.auth.uid];
      return isSignedIn() && (
        ws.ownerUserId == request.auth.uid || 
        role == 'lead' || 
        role == 'owner'
      );
    }

    function isWorkspaceOwner(wsId) {
      let ws = getWorkspace(wsId);
      return isSignedIn() && ws.ownerUserId == request.auth.uid;
    }

    // --- COLLECTION GROUP RULES ---
    
    match /{path=**}/tasks/{taskId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/comments/{commentId} {
      allow read: if isSignedIn();
    }

    // --- HIERARCHICAL RULES ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /invitations/{inviteId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && isWorkspaceOwner(resource.data.workspaceId);
    }

    match /workspaces/{workspaceId} {
      // Allow any signed in user to list/get workspace metadata for discovery/joining
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isWorkspaceOwner(workspaceId);
      // Allow update for joining (adding roles) or admin management
      allow update: if isSignedIn();

      match /members/{memberUserId} {
        allow read: if isSignedIn();
        allow write: if (isSignedIn() && request.auth.uid == memberUserId) || isWorkspaceAdmin(workspaceId);
      }

      match /projects/{projectId} {
        allow read: if isWorkspaceMember(workspaceId);
        allow write: if isWorkspaceAdmin(workspaceId);

        match /tasks/{taskId} {
          allow read: if isWorkspaceMember(workspaceId);
          allow write: if isWorkspaceAdmin(workspaceId);

          match /comments/{commentId} {
            allow read: if isWorkspaceMember(workspaceId);
            allow write: if isWorkspaceMember(workspaceId);
          }
        }
      }
    }
  }
}