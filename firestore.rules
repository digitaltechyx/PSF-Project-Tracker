rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Standardized membership check for map-based roles
    function isMember(data) {
      return isSignedIn() && 
             data != null && 
             data.memberRoles != null && 
             data.memberRoles[request.auth.uid] != null;
    }

    function isAdmin(data) {
      return isSignedIn() && 
             data != null && 
             data.memberRoles != null && 
             (data.memberRoles[request.auth.uid] == 'admin' || data.memberRoles[request.auth.uid] == 'owner');
    }

    // --- COLLECTION GROUP RULES ---
    // These must be defined to authorize collectionGroup() queries used in Dashboard and Global views.
    // The query MUST include a filter on memberRoles[uid] to be provable.

    match /{path=**}/tasks/{taskId} {
      allow list, get: if isMember(resource.data);
    }

    match /{path=**}/comments/{commentId} {
      allow list, get: if isMember(resource.data);
    }

    // --- HIERARCHICAL COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; 
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    match /workspaces/{workspaceId} {
      // workspace listing requires a filter on memberRoles[uid]
      allow list: if isMember(resource.data);
      allow get: if isMember(resource.data) || isOwner(resource.data.ownerUserId);
      allow create: if isSignedIn() && request.resource.data.ownerUserId == request.auth.uid;
      allow update: if resource != null && (resource.data.ownerUserId == request.auth.uid || isAdmin(resource.data)) && request.resource.data.ownerUserId == resource.data.ownerUserId;
      allow delete: if resource != null && resource.data.ownerUserId == request.auth.uid;

      match /members/{memberUserId} {
        allow get, list: if isMember(get(/databases/$(database)/documents/workspaces/$(workspaceId)).data) || isOwner(memberUserId);
        allow create: if isSignedIn() && isAdmin(get(/databases/$(database)/documents/workspaces/$(workspaceId)).data);
        allow update: if resource != null && (isAdmin(get(/databases/$(database)/documents/workspaces/$(workspaceId)).data) || isOwner(memberUserId));
        allow delete: if resource != null && (isAdmin(get(/databases/$(database)/documents/workspaces/$(workspaceId)).data) || isOwner(memberUserId));
      }

      match /projects/{projectId} {
        allow get, list: if isMember(resource.data);
        allow create: if isSignedIn() && isAdmin(request.resource.data);
        allow update: if resource != null && isAdmin(resource.data);
        allow delete: if resource != null && isAdmin(resource.data);

        // Hierarchical matches for nested tasks/comments
        match /tasks/{taskId} {
          allow create: if isSignedIn() && isMember(request.resource.data);
          allow update: if resource != null && isMember(resource.data);
          allow delete: if resource != null && isAdmin(resource.data);

          match /comments/{commentId} {
            allow create: if isSignedIn() && isMember(request.resource.data) && request.resource.data.authorUserId == request.auth.uid;
            allow update: if resource != null && (isOwner(resource.data.authorUserId) || isAdmin(resource.data)) && request.resource.data.authorUserId == resource.data.authorUserId;
            allow delete: if resource != null && (isOwner(resource.data.authorUserId) || isAdmin(resource.data));
          }
        }
      }
    }
  }
}