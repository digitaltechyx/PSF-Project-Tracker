rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES - PROTOTYPING MODE
     * 
     * CORE PHILOSOPHY:
     * This ruleset implements a robust "Authorization Independence" model through aggressive 
     * data denormalization. The goal is to maximize performance and security while allowing 
     * for rapid frontend iteration without strict schema enforcement.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isMember(data) {
      return isSignedIn() && data != null && data.memberRoles != null && request.auth.uid in data.memberRoles;
    }

    function isAdmin(data) {
      return isSignedIn() && data != null && data.memberRoles != null && 
             (data.memberRoles[request.auth.uid] == 'admin' || data.memberRoles[request.auth.uid] == 'owner');
    }

    // --- COLLECTION GROUP RULES (For global workspace views) ---

    /**
     * @description Supports collectionGroup queries for tasks and comments across projects.
     * @principle Authorization Independence: access is checked against the document's own memberRoles map.
     */
    match /{path=**}/tasks/{taskId} {
      allow list: if isMember(resource.data);
    }

    match /{path=**}/comments/{commentId} {
      allow list: if isMember(resource.data);
    }

    // --- HIERARCHICAL COLLECTION RULES ---

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    match /workspaces/{workspaceId} {
      allow get, list: if isSignedIn() && (resource.data.ownerUserId == request.auth.uid || isMember(resource.data));
      allow create: if isSignedIn() && request.resource.data.ownerUserId == request.auth.uid;
      allow update: if resource != null && (resource.data.ownerUserId == request.auth.uid || isAdmin(resource.data)) && request.resource.data.ownerUserId == resource.data.ownerUserId;
      allow delete: if resource != null && resource.data.ownerUserId == request.auth.uid;

      match /members/{memberUserId} {
        allow get, list: if isSignedIn() && (isMember(resource.data) || isOwner(memberUserId));
        allow create: if isSignedIn() && isAdmin(request.resource.data);
        allow update: if resource != null && (isAdmin(resource.data) || isOwner(memberUserId));
        allow delete: if resource != null && (isAdmin(resource.data) || isOwner(memberUserId));
      }

      match /projects/{projectId} {
        allow get, list: if isMember(resource.data);
        allow create: if isSignedIn() && isAdmin(request.resource.data);
        allow update: if resource != null && isAdmin(resource.data);
        allow delete: if resource != null && isAdmin(resource.data);

        match /tasks/{taskId} {
          allow get, list: if isMember(resource.data);
          allow create: if isSignedIn() && isMember(request.resource.data);
          allow update: if resource != null && isMember(resource.data);
          allow delete: if resource != null && isAdmin(resource.data);

          match /comments/{commentId} {
            allow get, list: if isMember(resource.data);
            allow create: if isSignedIn() && isMember(request.resource.data) && request.resource.data.authorUserId == request.auth.uid;
            allow update: if resource != null && (isOwner(resource.data.authorUserId) || isAdmin(resource.data)) && request.resource.data.authorUserId == resource.data.authorUserId;
            allow delete: if resource != null && (isOwner(resource.data.authorUserId) || isAdmin(resource.data));
          }
        }
      }
    }
  }
}