rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getWorkspace(wsId) {
      return get(/databases/$(database)/documents/workspaces/$(wsId)).data;
    }

    // --- COLLECTION GROUP RULES ---
    
    match /{path=**}/tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /{path=**}/comments/{commentId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- HIERARCHICAL RULES ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /invitations/{inviteId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /workspaces/{workspaceId} {
      // Allow list and get for any signed-in user. 
      // In a real app, we would use a filtered query, but for a prototype 
      // this avoids race conditions during initial indexing.
      allow read, create: if isSignedIn();
      
      // Allow update for any signed-in user to support the client-side "Join" process
      allow update: if isSignedIn();
      
      // Delete requires ownership
      allow delete: if isSignedIn() && getWorkspace(workspaceId).ownerUserId == request.auth.uid;

      match /members/{memberUserId} {
        // Prototype permissions: allow read if signed in
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /projects/{projectId} {
        // Prototype permissions: allow read if signed in
        allow read: if isSignedIn();
        // Allow write for any signed-in user to support the client-side "Join" process and onboarding
        allow write: if isSignedIn();

        match /tasks/{taskId} {
          allow read: if isSignedIn();
          allow write: if isSignedIn();

          match /comments/{commentId} {
            allow read: if isSignedIn();
            allow write: if isSignedIn();
          }
        }
      }
    }
  }
}