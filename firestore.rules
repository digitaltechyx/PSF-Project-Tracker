rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getWorkspace(wsId) {
      return get(/databases/$(database)/documents/workspaces/$(wsId)).data;
    }

    function isWorkspaceMember(wsId) {
      let ws = getWorkspace(wsId);
      return isSignedIn() && ws != null && (
        ws.ownerUserId == request.auth.uid || 
        (ws.memberRoles != null && request.auth.uid in ws.memberRoles)
      );
    }

    function isWorkspaceAdmin(wsId) {
      let ws = getWorkspace(wsId);
      return isSignedIn() && ws != null && (
        ws.ownerUserId == request.auth.uid || 
        (ws.memberRoles != null && (
          ws.memberRoles[request.auth.uid] == 'owner' || 
          ws.memberRoles[request.auth.uid] == 'lead'
        ))
      );
    }

    // --- COLLECTION GROUP RULES ---
    
    match /{path=**}/tasks/{taskId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/comments/{commentId} {
      allow read: if isSignedIn();
    }

    // --- HIERARCHICAL RULES ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /invitations/{inviteId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /workspaces/{workspaceId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isWorkspaceAdmin(workspaceId);
      allow delete: if isSignedIn() && getWorkspace(workspaceId).ownerUserId == request.auth.uid;

      match /members/{memberUserId} {
        allow read: if isWorkspaceMember(workspaceId);
        allow write: if isWorkspaceAdmin(workspaceId) || (isSignedIn() && request.auth.uid == memberUserId);
      }

      match /projects/{projectId} {
        allow read: if isWorkspaceMember(workspaceId);
        allow write: if isWorkspaceAdmin(workspaceId);

        match /tasks/{taskId} {
          allow read: if isWorkspaceMember(workspaceId);
          allow write: if isWorkspaceMember(workspaceId);

          match /comments/{commentId} {
            allow read: if isWorkspaceMember(workspaceId);
            allow write: if isWorkspaceMember(workspaceId);
          }
        }
      }
    }
  }
}