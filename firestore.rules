
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // --- COLLECTION GROUP RULES ---
    
    match /{path=**}/tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /{path=**}/comments/{commentId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- HIERARCHICAL RULES ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Anyone can create a notification for another user
      allow create: if isSignedIn();
      // Users can mark their own notifications as read
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /invitations/{inviteId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /workspaces/{workspaceId} {
      allow read, create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerUserId == request.auth.uid;

      match /members/{memberUserId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /projects/{projectId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();

        match /tasks/{taskId} {
          allow read: if isSignedIn();
          allow write: if isSignedIn();

          match /comments/{commentId} {
            allow read: if isSignedIn();
            allow write: if isSignedIn();
          }
        }
      }
    }
  }
}
